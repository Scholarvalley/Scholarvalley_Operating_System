# Local dev: set these in .env. On AWS: inject via ECS task (Secrets Manager / SSM). See docs/AWS_ARCHITECTURE.md and infra/README.md.
DATABASE_URL=postgresql+psycopg2://scholarvalley:scholarvalley@db:5432/scholarvalley

JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# S3 – document uploads (transcript, degree). See docs/AWS_S3_SETUP.md.
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# For local/Docker: IAM credentials with s3:PutObject, s3:GetObject, s3:ListBucket on the bucket.
# On ECS the task role is used; these are not needed in production.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

SES_FROM_EMAIL=no-reply@example.com

